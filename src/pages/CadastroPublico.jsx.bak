import { useState } from 'react'
import { useNavigate } from 'react-router-dom'
import { supabase } from '../lib/supabase'

const bg = {background:'linear-gradient(135deg,#1a237e 0%,#283593 50%,#1565c0 100%)'}
const inp = 'w-full border border-gray-300 rounded-xl px-4 py-3 text-gray-800 focus:outline-none focus:ring-2 focus:ring-blue-400 bg-gray-50 text-sm'

export default function CadastroPublico() {
  const navigate = useNavigate()
  const [cpf, setCpf] = useState('')
  const [email, setEmail] = useState('')
  const [senha, setSenha] = useState('')
  const [confirmar, setConfirmar] = useState('')
  const [mostrarSenha, setMostrarSenha] = useState(false)
  const [carregando, setCarregando] = useState(false)
  const [erro, setErro] = useState('')
  const [aceitou, setAceitou] = useState(false)

  function formatCpf(v) {
    return v.replace(/\D/g,'').slice(0,11)
      .replace(/(\d{3})(\d)/,'$1.$2')
      .replace(/(\d{3})(\d)/,'$1.$2')
      .replace(/(\d{3})(\d{1,2})$/,'$1-$2')
  }

  const handleCadastro = async (e) => {
    e.preventDefault()
    setErro('')
    const cpfLimpo = cpf.replace(/\D/g,'')
    if (cpfLimpo.length !== 11) return setErro('CPF inválido.')
    if (!email.includes('@')) return setErro('E-mail inválido.')
    if (senha.length < 8) return setErro('A senha deve ter ao menos 8 caracteres.')
    if (senha !== confirmar) return setErro('As senhas não coincidem.')
    if (!aceitou) return setErro('Você precisa aceitar a declaração de responsabilidade.')
    setCarregando(true)
    try {
      // Verificar se CPF já existe
      const { data: existe } = await supabase
        .from('associados').select('id,status_cadastro').eq('cpf', cpfLimpo).maybeSingle()
      if (existe) {
        if (existe.status_cadastro === 'pendente') return setErro('Este CPF já possui um cadastro aguardando aprovação.')
        if (existe.status_cadastro === 'aprovado') return setErro('Este CPF já está cadastrado. Use a tela de login.')
        return setErro('CPF já registrado no sistema.')
      }
      // Criar conta Auth
      const { data: authData, error: authErr } = await supabase.auth.signUp({
        email: email.trim().toLowerCase(),
        password: senha,
        options: { emailRedirectTo: null }
      })
      if (authErr) {
        if (authErr.message.includes('already registered')) return setErro('Este e-mail já está em uso.')
        return setErro('Erro ao criar conta: ' + authErr.message)
      }
      const uid = authData.user?.id
      if (!uid) return setErro('Erro ao criar conta. Tente novamente.')
      // Inserir em associados com status pendente
      const { error: insErr } = await supabase.from('associados').insert({
        cpf: cpfLimpo,
        email: email.trim().toLowerCase(),
        user_id: uid,
        status_cadastro: 'pendente',
        situacao: 'inativo',
        cadastro_proprio: true,
        cadastrado_em: new Date().toISOString()
      })
      if (insErr) return setErro('Erro ao salvar cadastro: ' + insErr.message)
      // Criar perfil de acesso como Membro
      await supabase.from('perfis_acesso').insert({
        user_id: uid,
        perfil: 'Membro',
        is_admin: false
      })
      // Redirecionar para login com mensagem
      navigate('/', { state: { cadastroConcluido: true } })
    } catch(err) {
      setErro('Erro inesperado. Tente novamente.')
    } finally {
      setCarregando(false)
    }
  }

  return (
    <div className="min-h-screen flex items-center justify-center p-4" style={bg}>
      <div className="w-full max-w-md">

        <div className="text-center mb-6">
          <img src="/logo-acacia.png" alt="Acácia"
            className="w-20 h-20 mx-auto mb-3 rounded-full shadow-lg border-4 border-white/30"/>
          <h1 style={{color:'white', fontSize:'1.5rem', fontWeight:'bold'}}>Acácia de Serra Negra</h1>
          <p className="text-blue-200 text-sm mt-1">Loja Maçônica Nº 271 — GLESP</p>
        </div>

        <div className="bg-white rounded-3xl shadow-2xl overflow-hidden">
          <div className="h-1.5 bg-gradient-to-r from-blue-500 via-indigo-500 to-purple-500"/>
          <div className="p-6">

            <h2 className="text-xl font-bold text-gray-800 mb-1">Criar acesso</h2>
            <p className="text-gray-500 text-sm mb-4">Preencha seus dados de acesso. Após o cadastro, complete seu perfil e aguarde aprovação.</p>

            {/* Aviso LGPD */}
            <div style={{background:'#FFF8E1', border:'1px solid #F9A825', borderLeft:'4px solid #F57F17', borderRadius:8, padding:'12px 14px', marginBottom:16}}>
              <p style={{fontSize:11, fontWeight:700, color:'#E65100', marginBottom:4, textTransform:'uppercase', letterSpacing:'0.05em'}}>⚠️ Declaração de responsabilidade</p>
              <p style={{fontSize:11, color:'#5D4037', lineHeight:1.6, margin:0}}>
                As informações fornecidas neste cadastro e no preenchimento do perfil são de <strong>inteira responsabilidade do declarante</strong>.
                Ao prosseguir, você declara que os dados são <strong>verídicos, completos e atualizados</strong>, nos termos do art. 9º
                da Lei 13.709/2018 (LGPD). A Loja utilizará esses dados exclusivamente para fins administrativos e maçônicos,
                com total sigilo perante terceiros. O fornecimento de informações falsas poderá resultar no
                <strong> indeferimento ou cancelamento do cadastro</strong>.
              </p>
            </div>

            <form onSubmit={handleCadastro}>
              <div className="mb-3">
                <label className="block text-sm font-semibold text-gray-700 mb-1">CPF <span style={{color:'#e53e3e'}}>*</span></label>
                <input type="text" inputMode="numeric" className={inp}
                  placeholder="000.000.000-00" value={cpf} maxLength={14}
                  onChange={e => setCpf(formatCpf(e.target.value))} />
              </div>

              <div className="mb-3">
                <label className="block text-sm font-semibold text-gray-700 mb-1">E-mail <span style={{color:'#e53e3e'}}>*</span></label>
                <input type="email" className={inp}
                  placeholder="seu@email.com" value={email}
                  onChange={e => setEmail(e.target.value)} />
              </div>

              <div className="mb-3">
                <label className="block text-sm font-semibold text-gray-700 mb-1">Senha <span style={{color:'#e53e3e'}}>*</span></label>
                <div style={{position:'relative'}}>
                  <input type={mostrarSenha ? 'text' : 'password'} className={inp}
                    placeholder="Mínimo 8 caracteres" value={senha}
                    onChange={e => setSenha(e.target.value)} style={{paddingRight:44}} />
                  <button type="button" onClick={() => setMostrarSenha(v => !v)}
                    style={{position:'absolute', right:12, top:'50%', transform:'translateY(-50%)', background:'none', border:'none', cursor:'pointer', fontSize:18, color:'#94a3b8', padding:0}}>
                    {mostrarSenha ? '🙈' : '👁️'}
                  </button>
                </div>
              </div>

              <div className="mb-4">
                <label className="block text-sm font-semibold text-gray-700 mb-1">Confirmar senha <span style={{color:'#e53e3e'}}>*</span></label>
                <input type={mostrarSenha ? 'text' : 'password'} className={inp}
                  placeholder="Repita a senha" value={confirmar}
                  onChange={e => setConfirmar(e.target.value)} />
              </div>

              <label style={{display:'flex', alignItems:'flex-start', gap:10, marginBottom:16, cursor:'pointer'}}>
                <input type="checkbox" checked={aceitou} onChange={e => setAceitou(e.target.checked)}
                  style={{marginTop:3, flexShrink:0, width:16, height:16}} />
                <span style={{fontSize:11, color:'#4a5568', lineHeight:1.5}}>
                  Declaro que todas as informações fornecidas são verdadeiras e assumo total responsabilidade por elas, conforme a Lei 13.709/2018 (LGPD).
                </span>
              </label>

              {erro && (
                <div className="bg-red-50 border border-red-200 text-red-600 rounded-xl px-4 py-3 mb-4 text-sm">
                  {erro}
                </div>
              )}

              <button type="submit" disabled={carregando}
                className="w-full bg-gradient-to-r from-blue-600 to-indigo-600 text-white py-4 rounded-2xl font-bold hover:from-blue-700 hover:to-indigo-700 transition shadow-lg disabled:opacity-50">
                {carregando ? 'Criando acesso...' : 'Criar acesso'}
              </button>
            </form>

            <p className="text-center text-sm text-gray-400 mt-4">
              Já tem acesso?{' '}
              <span onClick={() => navigate('/')} style={{color:'#6366f1', cursor:'pointer', fontWeight:600}}>
                Entrar
              </span>
            </p>

          </div>
        </div>

        <p className="text-center text-blue-200/60 text-xs mt-4">
          Fundada em 15/11/1983 · Serra Negra, SP
        </p>
      </div>
    </div>
  )
}
